{
  "name": "@rivuty/http-status",
  "version": "2.0.1",
  "description": "Type-safe HTTP status codes",
  "keywords": [
    "http-status",
    "http-status-code",
    "status-code",
    "typescript"
  ],
  "license": "MIT",
  "author": "Oleg Michailov",
  "repository": {
    "type": "git",
    "url": "https://github.com/rivuty/http-status.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "typecheck": "tsc",
    "test": "vitest run",
    "verify": "run-p -c lint format typecheck test",
    "prepublishOnly": "run-p -c verify build",
    "release": "release-it"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@rivuty/oxfmt-config": "^1.0.0",
    "@rivuty/oxlint-config": "^1.2.0",
    "@types/node": "^25.5.2",
    "lefthook": "^2.1.5",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "release-it": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.3"
  },
  "packageManager": "pnpm@10.32.1"
}
